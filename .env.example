# ─────────────────────────────────────────────────────────────
# Database — source of truth (REQUIRED)
# Postgres connection string (Supabase / Neon). The API writes here first.
# ─────────────────────────────────────────────────────────────
DATABASE_URL=postgres://user:password@host:5432/dbname

# ─────────────────────────────────────────────────────────────
# CRM routing (per channel)
# ─────────────────────────────────────────────────────────────
# Global default provider: brevo | klaviyo
CRM_PROVIDER=brevo

# Optional overrides (default to CRM_PROVIDER if empty):
# Email is always sent from one platform worldwide.
CRM_EMAIL_PROVIDER=
# SMS default when no per-country rule matches.
CRM_SMS_PROVIDER=
# SMS platform per country (JSON map, ISO alpha-2 → provider).
# Example — US tour on Klaviyo, everyone else on the default (Brevo):
# CRM_SMS_COUNTRY_ROUTING={"US":"klaviyo","CA":"klaviyo"}
CRM_SMS_COUNTRY_ROUTING=

# ─────────────────────────────────────────────────────────────
# Provider API keys
# ─────────────────────────────────────────────────────────────
# Brevo (email + EU SMS) — required for the default setup
BREVO_API_KEY=your-brevo-api-key-here
# Optional: numeric Brevo list id to add contacts to
BREVO_LIST_ID=

# Klaviyo — only needed if a channel/country routes to Klaviyo
KLAVIYO_API_KEY=
